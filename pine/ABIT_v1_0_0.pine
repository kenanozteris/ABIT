//@version=6
strategy(
     "ABIT v1.0.0 - AI Bitcoin Institutional Trader",
     overlay = true,
     initial_capital = 10000,
     default_qty_type = strategy.percent_of_equity,
     default_qty_value = 10,
     commission_type = strategy.commission.percent,
     commission_value = 0.05,
     pyramiding = 0
)


//==================================================
// ABIT v1.0.0
// Core Framework
// BTCUSDT MEXC Futures
// Timeframe: 15M
//==================================================


//==================================================
// SETTINGS
//==================================================

groupTrend = "Trend Settings"

emaFastLen = input.int(
     20,
     "Fast EMA",
     group = groupTrend
)

emaSlowLen = input.int(
     50,
     "Slow EMA",
     group = groupTrend
)

emaLongLen = input.int(
     200,
     "Long EMA",
     group = groupTrend
)



groupRisk = "Risk Settings"

atrLen = input.int(
     14,
     "ATR Length",
     group = groupRisk
)

atrMultiplier = input.float(
     1.5,
     "ATR Stop Multiplier",
     step = 0.1,
     group = groupRisk
)


groupScore = "Score Settings"

minScore = input.int(
     80,
     "Minimum Trade Score",
     group = groupScore
)



//==================================================
// TIMEFRAME DATA
//==================================================

tfHigher = "240"


//==================================================
// TREND ENGINE
//==================================================


emaFast = ta.ema(
     close,
     emaFastLen
)

emaSlow = ta.ema(
     close,
     emaSlowLen
)

emaLong = ta.ema(
     close,
     emaLongLen
)



htfFast = request.security(
     syminfo.tickerid,
     tfHigher,
     ta.ema(close, emaFastLen)
)

htfSlow = request.security(
     syminfo.tickerid,
     tfHigher,
     ta.ema(close, emaSlowLen)
)



bullTrend =
     emaFast > emaSlow and
     emaSlow > emaLong and
     htfFast > htfSlow


bearTrend =
     emaFast < emaSlow and
     emaSlow < emaLong and
     htfFast < htfSlow



//==================================================
// SCORE ENGINE
//==================================================


var float score = 0


score := 0


// Trend score

if bullTrend
    score += 25

if bearTrend
    score += 25



// Volume placeholder

avgVolume = ta.sma(
     volume,
     20
)

volumeStrong =
     volume > avgVolume * 1.5


if volumeStrong
    score += 15



// Momentum placeholder

rsi = ta.rsi(
     close,
     14
)


momentumLong =
     rsi > 50


momentumShort =
     rsi < 50



if momentumLong or momentumShort
    score += 10



//==================================================
// MARKET STATE
//==================================================


marketState =
     bullTrend ? "BULL" :
     bearTrend ? "BEAR" :
     "RANGE"



//==================================================
// RISK ENGINE FOUNDATION
//==================================================

atr = ta.atr(
     atrLen
)


stopDistance =
     atr * atrMultiplier




//==================================================
// DASHBOARD v1.0.1
//==================================================


var table dash = table.new(
     position.top_right,
     3,
     9,
     border_width = 1
)



if barstate.islastconfirmedhistory or barstate.isrealtime

    table.cell(
         dash,
         0,
         0,
         "ABIT v1.0.1"
    )

    table.cell(
         dash,
         1,
         0,
         "BTCUSDT"
    )

    table.cell(
         dash,
         2,
         0,
         "15M"
    )


    table.cell(
         dash,
         0,
         1,
         "Market"
    )

    table.cell(
         dash,
         1,
         1,
         marketState
    )


    table.cell(
         dash,
         0,
         2,
         "Trend"
    )


    table.cell(
         dash,
         1,
         2,
         bullTrend ? "BULL" :
         bearTrend ? "BEAR" :
         "NEUTRAL"
    )


    table.cell(
         dash,
         0,
         3,
         "Score"
    )

    table.cell(
         dash,
         1,
         3,
         str.tostring(score) + "/50"
    )


    table.cell(
         dash,
         0,
         4,
         "Volume"
    )

    table.cell(
         dash,
         1,
         4,
         volumeStrong ? "STRONG" : "NORMAL"
    )


    table.cell(
         dash,
         0,
         5,
         "RSI"
    )

    table.cell(
         dash,
         1,
         5,
         str.tostring(rsi,"#.0")
    )


    table.cell(
         dash,
         0,
         6,
         "ATR"
    )

    table.cell(
         dash,
         1,
         6,
         str.tostring(stopDistance,"#.##")
    )


    table.cell(
         dash,
         0,
         7,
         "Status"
    )


    table.cell(
         dash,
         1,
         7,
         score >= minScore ? 
         "READY" :
         "WAIT"
    )

//==================================================
// VISUALS
//==================================================


plot(
     emaFast,
     color=color.green,
     title="EMA20"
)

plot(
     emaSlow,
     color=color.orange,
     title="EMA50"
)

plot(
     emaLong,
     color=color.red,
     title="EMA200"
)
